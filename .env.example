# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values before `docker compose up`.
# The .env file is git-ignored — DO NOT commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
DB_USER=user
DB_PASSWORD=change-me-strong-password
DB_NAME=moodbrief_db
DATABASE_URL=postgresql://user:change-me-strong-password@db:5432/moodbrief_db

# ── OpenRouter API ──────────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 48
SECRET_KEY=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set True ONLY when serving over HTTPS — otherwise the browser drops the
# cookie and login silently breaks.
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# ── CORS ────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost", "http://127.0.0.1"]
ALLOW_DEVTUNNELS=False

# ── Networking inside docker ────────────────────────────────────────────────
API_URL=http://backend:8000
# Empty = same-origin (nginx routes /api -> backend). Override only if you
# bypass nginx.
NEXT_PUBLIC_API_URL=
